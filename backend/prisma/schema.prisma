generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Sale {
  id    Int      @id @default(autoincrement())
  date  DateTime @default(now())
  total Float
  items Item[]
}

model Item {
  id     Int    @id @default(autoincrement())
  name   String
  price  Float
  qty    Int
  saleId Int
  sale   Sale   @relation(fields: [saleId], references: [id])
}
